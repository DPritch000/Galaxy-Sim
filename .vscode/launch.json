{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome (open http://localhost:5173)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client",
      "userDataDir": "${workspaceFolder}/.vscode/chrome",
      "preLaunchTask": "Run Dev Server"
    },
    {
      "name": "Attach to Chrome",
      "type": "pwa-chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/client"
    }
  ]
}
